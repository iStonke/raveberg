COMPOSE_PROJECT_NAME=raveberg

APP_ENV=development
PROXY_HOST_PORT=8085
FRONTEND_HOST_PORT=5180
BACKEND_HOST_PORT=8050
POSTGRES_HOST_PORT=5435

POSTGRES_DB=raveberg
POSTGRES_USER=raveberg
POSTGRES_PASSWORD=change-me

BACKEND_CORS_ORIGINS=http://localhost:8085,http://127.0.0.1:8085,http://localhost:5180,http://127.0.0.1:5180
DEFAULT_APP_MODE=visualizer
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-me
SESSION_TTL_HOURS=24
UPLOAD_MAX_BYTES=15728640

APP_DATA_PATH=/app/data
UPLOADS_PATH=/app/data/uploads
DISPLAY_CACHE_PATH=/app/data/display-cache
