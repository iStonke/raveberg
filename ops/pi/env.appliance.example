APP_ENV=appliance
APPLIANCE_MODE=true

PROXY_HOST_PORT=8085
FRONTEND_HOST_PORT=5180
BACKEND_HOST_PORT=8050
POSTGRES_HOST_PORT=5435

PUBLIC_BASE_URL=http://10.77.0.1:8085
# Public guest-upload URL for QR codes on the display.
# Set this to a Quick Tunnel or your permanent public domain.
GUEST_UPLOAD_URL=https://your-public-upload-host.example/guest/upload
GUEST_UPLOAD_PATH=/guest/upload
ADMIN_PATH=/admin/login
DISPLAY_PATH=/display
# Keep the kiosk on /display. The preferred production path is local rendering on a strong Mac/PC;
# remote_headless remains an optional reserve path.
KIOSK_START_URL=http://10.77.0.1:8085/display

EVENT_NAME=RAVEBERG Keller Session
EVENT_TAGLINE=Techno im Fahrradkeller
DISPLAY_OVERLAY_ENABLED=true
DISPLAY_RENDER_MODE=local
REMOTE_RENDERER_BASE_URL=
REMOTE_RENDERER_OUTPUT_PATH=/preview
REMOTE_RENDERER_HEALTH_URL=
REMOTE_RENDERER_RECONNECT_MS=3000
REMOTE_RENDERER_FALLBACK=local
AP_ENABLED=true
AP_SSID=RAVEBERG
AP_ADDRESS=10.77.0.1
LOCAL_HOSTNAME=raveberg.local

DEFAULT_APP_MODE=visualizer
DEFAULT_MODERATION_MODE=manual_approve
DEFAULT_SLIDESHOW_ENABLED=true
DEFAULT_SLIDESHOW_INTERVAL_SECONDS=6
DEFAULT_SLIDESHOW_SHUFFLE=true
DEFAULT_VISUALIZER_AUTO_CYCLE_ENABLED=false
DEFAULT_VISUALIZER_AUTO_CYCLE_INTERVAL_SECONDS=60
UPLOAD_RATE_LIMIT_COUNT=6
UPLOAD_RATE_LIMIT_WINDOW_SECONDS=60
MAX_STORED_UPLOADS=600
CLEANUP_PRESERVE_LATEST_COUNT=160
CLEANUP_BATCH_SIZE=60
DISPLAY_HEARTBEAT_INTERVAL_SECONDS=15
DISPLAY_HEARTBEAT_STALE_SECONDS=45
