# Renderer-Rechner: Beispielkonfiguration fuer renderer_headless

HEADLESS_RENDERER_HOST=0.0.0.0
HEADLESS_RENDERER_PORT=9012
HEADLESS_RENDERER_DISPLAY_URL=http://192.168.178.38:8085/display?renderer=1

HEADLESS_RENDERER_WIDTH=1920
HEADLESS_RENDERER_HEIGHT=1080
HEADLESS_RENDERER_FPS=12
HEADLESS_RENDERER_JPEG_QUALITY=80
HEADLESS_RENDERER_KEYFRAME_INTERVAL=24

HEADLESS_RENDERER_ENCODER=libx264
HEADLESS_RENDERER_PRESET=veryfast
HEADLESS_RENDERER_VIDEO_BITRATE=4500k
HEADLESS_RENDERER_MAXRATE=6000k
HEADLESS_RENDERER_BUFSIZE=9000k

HEADLESS_RENDERER_HLS_TIME=1
HEADLESS_RENDERER_HLS_LIST_SIZE=4

HEADLESS_RENDERER_STARTUP_GRACE_MS=30000
HEADLESS_RENDERER_OUTPUT_STALE_MS=15000
HEADLESS_RENDERER_WATCHDOG_ENABLED=true
HEADLESS_RENDERER_WATCHDOG_INTERVAL_MS=10000
HEADLESS_RENDERER_WATCHDOG_FAILURE_THRESHOLD=3

# Optional:
# HEADLESS_RENDERER_BROWSER_CHANNEL=chrome
# HEADLESS_RENDERER_BROWSER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# HEADLESS_RENDERER_FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
